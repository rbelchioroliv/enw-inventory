generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRAGMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Equipment {
  id               String   @id @default(cuid())
  empresa          String   
  patrimonio       String   @unique
  numeroSerie      String?   @unique
  macAddress       String
  modelo           String
  configuracoes    String   
  idadeHardware    Int      
  numeroReparos    Int      @default(0)
  alertaTroca      Boolean  @default(false)
  usuarioAtual     String
  emailCorporativo String
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  criadoEm  DateTime @default(now())
}