generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Equipment {
  id               String   @id @default(cuid())
  empresa          String   
  departamento     String   // NOVO CAMPO
  patrimonio       String   @unique
  numeroSerie      String?  @unique
  modelo           String
  configuracoes    String   
  idadeHardware    Int      
  numeroReparos    Int      @default(0)
  alertaTroca      Boolean  @default(false)
  usuarioAtual     String
  emailCorporativo String
  
  // Periféricos (Opcionais)
  monitorSecundario           String?
  monitorSecundarioSN         String?
  monitorSecundarioPatrimonio String?
  teclado                     String?
  tecladoSN                   String?
  mouse                       String?
  mouseSN                     String?
  headset                     String?
  headsetSN                   String?

  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  criadoEm  DateTime @default(now())
}